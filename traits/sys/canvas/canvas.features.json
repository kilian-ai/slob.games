{
  "features": [
    {
      "name": "set canvas content (creates game if none active)",
      "examples": [
        {
          "input": { "args": ["set", "<h1>Hello</h1>"] },
          "output": { "contains": "\"ok\":true" }
        }
      ]
    },
    {
      "name": "get active game content",
      "examples": [
        {
          "input": { "args": ["get"] },
          "output": { "contains": "\"ok\":true" }
        }
      ]
    },
    {
      "name": "clear active game",
      "examples": [
        {
          "input": { "args": ["clear"] },
          "output": { "contains": "\"ok\":true" }
        }
      ]
    },
    {
      "name": "create new game",
      "examples": [
        {
          "input": { "args": ["new", "my-game"] },
          "output": { "contains": "\"action\":\"new\"" }
        }
      ]
    },
    {
      "name": "list all games",
      "examples": [
        {
          "input": { "args": ["games"] },
          "output": { "contains": "\"games\":" }
        }
      ]
    },
    {
      "name": "activate game by id",
      "examples": [
        {
          "input": { "args": ["activate", "nonexistent"] },
          "output": { "contains": "\"error\":" }
        }
      ]
    },
    {
      "name": "rename active game",
      "examples": [
        {
          "input": { "args": ["rename", "cool-game"] },
          "output": { "contains": "\"ok\":" }
        }
      ]
    },
    {
      "name": "delete game by id",
      "examples": [
        {
          "input": { "args": ["delete", "nonexistent"] },
          "output": { "contains": "\"ok\":true" }
        }
      ]
    },
    {
      "name": "get VFS paths",
      "examples": [
        {
          "input": { "args": ["path"] },
          "output": { "contains": "\"games_path\":\"canvas/games.json\"" }
        }
      ]
    },
    {
      "name": "legacy: save (rename alias)",
      "examples": [
        {
          "input": { "args": ["save", "test-name"] },
          "output": { "contains": "\"action\":\"save\"" }
        }
      ]
    },
    {
      "name": "legacy: projects (games alias)",
      "examples": [
        {
          "input": { "args": ["projects"] },
          "output": { "contains": "\"games\":" }
        }
      ]
    }
  ]
}
